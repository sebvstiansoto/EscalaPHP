# Producción — copia a .env y ajusta valores

APP_DEBUG=false
APP_URL=https://tu-dominio.com
APP_KEY=GENERA_CON_scripts_generate-key.sh

ADMIN_PASSWORD=cambia-esta-contraseña-segura

# SQLite (recomendado para un solo servidor Docker)
DB_DRIVER=sqlite
DB_PATH=database/escala.sqlite

# PostgreSQL (perfil opcional: docker compose --profile postgres)
# DB_DRIVER=pgsql
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=escala
# DB_USER=escala
# DB_PASS=contraseña-larga-aleatoria

LOG_PATH=storage/logs/app.log
MAIL_DRIVER=log
MAIL_FROM=noreply@tu-dominio.com

# SMTP producción (recomendado)
# MAIL_DRIVER=smtp
# SMTP_HOST=smtp.tu-proveedor.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_TRIAL_DAYS=7

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DOCKER_RUNNER=false

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

BACKUP_PATH=storage/backups

# Docker Compose
HTTP_PORT=80
