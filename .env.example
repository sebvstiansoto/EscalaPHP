APP_DEBUG=false
APP_URL=http://localhost:8000
APP_KEY=change-me-in-production-use-long-random-string
ADMIN_PASSWORD=escala-admin-change-me

DB_DRIVER=sqlite
DB_PATH=database/escala.sqlite
# DB_DRIVER=pgsql
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=escala
# DB_USER=escala
# DB_PASS=secret

LOG_PATH=storage/logs/app.log
MAIL_DRIVER=log
MAIL_FROM=noreply@escala.dev
# MAIL_DRIVER=smtp

# Stripe (opcional — sin esto, checkout activa Pro en modo dev)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_TRIAL_DAYS=7

# Mentor IA (opcional — sin esto usa reglas locales)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ejecución aislada con Docker (opcional)
DOCKER_RUNNER=false

# OAuth GitHub (opcional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

BACKUP_PATH=storage/backups
