# Variables para Railway (Dashboard → Service → Variables)
# No subas este archivo con secretos reales.

APP_DEBUG=false
# APP_URL se detecta solo desde RAILWAY_PUBLIC_DOMAIN si no la defines
APP_KEY=genera-con-openssl-rand-hex-32

ADMIN_PASSWORD=cambia-esta-contraseña

DB_DRIVER=sqlite
DB_PATH=database/escala.sqlite

LOG_PATH=storage/logs/app.log
MAIL_DRIVER=log
MAIL_FROM=noreply@escala.dev

# Opcional — pagos
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Opcional — mentor IA
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

BACKUP_PATH=storage/backups

CRON_SECRET=genera-un-secreto-largo

# ANALYTICS_DOMAIN=escalaphp-production.up.railway.app

# Email: log | resend | smtp
MAIL_DRIVER=log
# MAIL_DRIVER=resend
# RESEND_API_KEY=re_...
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_...
